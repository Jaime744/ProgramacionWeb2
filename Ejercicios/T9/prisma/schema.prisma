// prisma/schema.prisma
// Define los modelos de la base de datos y cómo se relacionan entre sí

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Role {
  USER
  LIBRARIAN
  ADMIN
}

enum LoanStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

// ─── MODELOS ──────────────────────────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  password  String   // Almacenado como hash bcrypt
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones: un usuario puede tener muchos préstamos y reseñas
  loans   Loan[]
  reviews Review[]

  @@map("users") // nombre de la tabla en la BD
}

model Book {
  id            Int      @id @default(autoincrement())
  isbn          String   @unique
  title         String
  author        String
  genre         String
  description   String?  // nullable
  publishedYear Int
  copies        Int      // total de ejemplares
  available     Int      // ejemplares disponibles ahora mismo
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  loans   Loan[]
  reviews Review[]

  @@map("books")
}

model Loan {
  id         Int        @id @default(autoincrement())
  userId     Int
  bookId     Int
  loanDate   DateTime   @default(now())
  dueDate    DateTime   // fecha límite: loanDate + 14 días
  returnDate DateTime?  // nullable — se rellena al devolver
  status     LoanStatus @default(ACTIVE)

  // Relaciones con sus modelos padre
  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  @@map("loans")
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int
  bookId    Int
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  // Un usuario solo puede reseñar un libro una vez
  @@unique([userId, bookId])
  @@map("reviews")
}
