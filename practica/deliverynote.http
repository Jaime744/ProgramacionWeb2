### BildyApp API — Albaranes (REST Client para VS Code)

@base = http://localhost:3000/api
@token = PEGA_AQUI_EL_ACCESS_TOKEN_DEL_LOGIN
@clientId  = PEGA_AQUI_EL_ID_DEL_CLIENTE
@projectId = PEGA_AQUI_EL_ID_DEL_PROYECTO
@noteId    = PEGA_AQUI_UN_ID_TRAS_CREAR

# ─────────────────────────────────────────────────────────────
# 1a) Crear albarán formato MATERIAL
# ─────────────────────────────────────────────────────────────
POST {{base}}/deliverynote
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "client": "{{clientId}}",
  "project": "{{projectId}}",
  "format": "material",
  "description": "Suministro de cemento para la obra",
  "workDate": "2025-05-12",
  "material": "Cemento Portland",
  "quantity": 25,
  "unit": "kg"
}

###

# ─────────────────────────────────────────────────────────────
# 1b) Crear albarán formato HOURS
# ─────────────────────────────────────────────────────────────
POST {{base}}/deliverynote
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "client": "{{clientId}}",
  "project": "{{projectId}}",
  "format": "hours",
  "description": "Trabajos de albañilería",
  "workDate": "2025-05-13",
  "hours": 16,
  "workers": [
    { "name": "Juan Pérez", "hours": 8 },
    { "name": "Ana López",  "hours": 8 }
  ]
}

###

# ─────────────────────────────────────────────────────────────
# 2) Listar albaranes (paginado por defecto: page=1&limit=10)
# ─────────────────────────────────────────────────────────────
GET {{base}}/deliverynote
Authorization: Bearer {{token}}

###

# 2b) Paginación + filtros por proyecto, cliente y formato
GET {{base}}/deliverynote?page=1&limit=5&project={{projectId}}&client={{clientId}}&format=material&sort=-workDate
Authorization: Bearer {{token}}

###

# 2c) Solo firmados, en un rango de fechas
GET {{base}}/deliverynote?signed=true&from=2025-05-01&to=2025-05-31
Authorization: Bearer {{token}}

###

# 2d) Solo no firmados
GET {{base}}/deliverynote?signed=false
Authorization: Bearer {{token}}

###

# ─────────────────────────────────────────────────────────────
# 3) Obtener un albarán (con populate de user, client y project)
# ─────────────────────────────────────────────────────────────
GET {{base}}/deliverynote/{{noteId}}
Authorization: Bearer {{token}}

###

# ─────────────────────────────────────────────────────────────
# 4) Actualizar albarán (solo si no está firmado)
# ─────────────────────────────────────────────────────────────
PUT {{base}}/deliverynote/{{noteId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "description": "Suministro corregido tras revisión",
  "quantity": 30
}

###

# ─────────────────────────────────────────────────────────────
# 5a) Soft delete (archivar)
# ─────────────────────────────────────────────────────────────
DELETE {{base}}/deliverynote/{{noteId}}?soft=true
Authorization: Bearer {{token}}

###

# 5b) Hard delete
DELETE {{base}}/deliverynote/{{noteId}}
Authorization: Bearer {{token}}

###

# ─────────────────────────────────────────────────────────────
# Caso error: faltan campos obligatorios para format=material → 400
# ─────────────────────────────────────────────────────────────
POST {{base}}/deliverynote
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "client": "{{clientId}}",
  "project": "{{projectId}}",
  "format": "material",
  "workDate": "2025-05-12"
}

###

# Caso error: project no pertenece al client → 400
POST {{base}}/deliverynote
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "client": "000000000000000000000000",
  "project": "{{projectId}}",
  "format": "hours",
  "workDate": "2025-05-12",
  "workers": [{ "name": "Test", "hours": 1 }]
}

###

# ─────────────────────────────────────────────────────────────
# Fase 3 — 6) Firmar albarán (multipart/form-data)
# Coloca un archivo "firma.png" junto a este .http para que el
# REST Client lo cargue con "< firma.png".
# ─────────────────────────────────────────────────────────────
PATCH {{base}}/deliverynote/{{noteId}}/sign
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=----BildyBoundary

------BildyBoundary
Content-Disposition: form-data; name="signature"; filename="firma.png"
Content-Type: image/png

< ./firma.png
------BildyBoundary--

###

# ─────────────────────────────────────────────────────────────
# Fase 3 — 7) Descargar / redirigir al PDF del albarán
# Si pdfUrl ya existe → 302 a R2. Si no, lo genera al vuelo.
# ─────────────────────────────────────────────────────────────
GET {{base}}/deliverynote/pdf/{{noteId}}
Authorization: Bearer {{token}}

###

# ─────────────────────────────────────────────────────────────
# Fase 3 — 8) Casos de error de firma / inmutabilidad
# ─────────────────────────────────────────────────────────────

# 8a) Intentar modificar un albarán firmado → 409
PUT {{base}}/deliverynote/{{noteId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "description": "Esto no debería poder modificarse"
}

###

# 8b) Intentar borrar un albarán firmado → 409
DELETE {{base}}/deliverynote/{{noteId}}
Authorization: Bearer {{token}}

###

# 8c) Intentar firmar dos veces → 409
PATCH {{base}}/deliverynote/{{noteId}}/sign
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=----BildyBoundary

------BildyBoundary
Content-Disposition: form-data; name="signature"; filename="firma.png"
Content-Type: image/png

< ./firma.png
------BildyBoundary--
